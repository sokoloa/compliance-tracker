# Database (Docker Compose sets this automatically)
DATABASE_URL="postgresql://compliance:compliance@localhost:5432/compliance_tracker"

# NextAuth - generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret-string"

# Where uploaded files are stored (inside container it maps to the volume)
UPLOAD_DIR="./uploads"

# App URL (used by NextAuth)
NEXTAUTH_URL="http://localhost:3000"
